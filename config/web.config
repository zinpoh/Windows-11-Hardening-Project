<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <!-- Control SC-7: Protección de perímetro -->
        <security>
            <requestFiltering>
                <!-- Ocultar directorios sensibles -->
                <hiddenSegments>
                    <add segment="Microsoft" />
                    <add segment="LogFiles" />
                    <add segment="recovery" />
                    <add segment="Protect" />
                    <add segment="keywords" />
                    <add segment="licenses" />
                    <add segment="tasks" />
                </hiddenSegments>
                <!-- Bloquear extensiones peligrosas -->
                <fileExtensions allowUnlisted="false">
                    <add fileExtension=".config" allowed="false" />
                    <add fileExtension=".ini" allowed="false" />
                    <add fileExtension=".xml" allowed="false" />
                    <add fileExtension=".log" allowed="false" />
                    <add fileExtension=".bak" allowed="false" />
                    <add fileExtension=".sql" allowed="false" />
                </fileExtensions>
                <!-- Limitar tamaño de peticiones -->
                <requestLimits maxAllowedContentLength="30000000" />
            </requestFiltering>
        </security>

        <!-- Control CM-6: Configuración segura -->
        <!-- Deshabilitar listado de directorios -->
        <directoryBrowse enabled="false" />
        
        <!-- Ocultar errores detallados -->
        <httpErrors errorMode="DetailedLocalOnly" />
        
        <!-- Control AC-3: Control de acceso -->
        <authorization>
            <remove users="*" roles="" verbs="" />
            <add accessType="Allow" users="Administrator" />
        </authorization>
        
        <!-- Control AC-4: Control de flujo de información -->
        <httpProtocol>
            <customHeaders>
                <!-- Prevenir ataques XSS -->
                <add name="X-XSS-Protection" value="1; mode=block" />
                <!-- Prevenir MIME sniffing -->
                <add name="X-Content-Type-Options" value="nosniff" />
                <!-- Prevenir clickjacking -->
                <add name="X-Frame-Options" value="DENY" />
                <!-- Política de seguridad de contenido -->
                <add name="Content-Security-Policy" value="default-src 'self'" />
            </customHeaders>
        </httpProtocol>
    </system.webServer>
</configuration>